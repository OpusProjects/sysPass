{
  "openapi": "3.0.3",
  "info": {
    "title": "sysPass API",
    "description": "sysPass password manager JSON-RPC 2.0 API.\n\nAll requests are `POST /api.php` with a JSON-RPC envelope. The `method` field selects the operation (e.g. `account/search`). Parameters go inside `params` alongside `authToken`.\n\n**Authentication:** Every request must include an `authToken` in `params`. Create tokens in the web UI under Users > Authorizations.",
    "version": "@@VERSION@@",
    "license": {
      "name": "GPL-3.0",
      "url": "https://www.gnu.org/licenses/gpl-3.0.html"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "Current server"
    }
  ],
  "tags": [
    {"name": "Account", "description": "Password account management"},
    {"name": "Category", "description": "Category management"},
    {"name": "Client", "description": "Client management"},
    {"name": "Tag", "description": "Tag management"},
    {"name": "UserGroup", "description": "User group management"},
    {"name": "Config", "description": "Backup and export"}
  ],
  "paths": {
    "/api.php#account/view": {
      "post": {
        "tags": ["Account"],
        "summary": "View account",
        "operationId": "accountView",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JsonRpcRequest"
              },
              "example": {
                "jsonrpc": "2.0",
                "method": "account/view",
                "params": {
                  "authToken": "your_token_here",
                  "id": 1,
                  "customFields": false,
                  "tokenPass": "token_password"
                },
                "id": 1
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account details",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/JsonRpcSuccessResponse"}
              }
            }
          },
          "500": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/JsonRpcErrorResponse"}
              }
            }
          }
        },
        "description": "Retrieve a single account by ID.\n\n**Method:** `account/view`\n\n**Params:**\n| Name | Type | Required | Description |\n|------|------|----------|-------------|\n| authToken | string | yes | API auth token |\n| id | integer | yes | Account ID |\n| customFields | boolean | no | Include custom fields in response |\n| tokenPass | string | yes* | Token password (required when customFields is true) |"
      }
    },
    "/api.php#account/viewPass": {
      "post": {
        "tags": ["Account"],
        "summary": "View account password",
        "operationId": "accountViewPass",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/JsonRpcRequest"},
              "example": {
                "jsonrpc": "2.0",
                "method": "account/viewPass",
                "params": {
                  "authToken": "your_token_here",
                  "id": 1,
                  "tokenPass": "token_password",
                  "details": true
                },
                "id": 1
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account password",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/JsonRpcSuccessResponse"}
              }
            }
          }
        },
        "description": "Retrieve the decrypted password for an account.\n\n**Method:** `account/viewPass`\n\n**Params:**\n| Name | Type | Required | Description |\n|------|------|----------|-------------|\n| authToken | string | yes | API auth token |\n| id | integer | yes | Account ID |\n| tokenPass | string | yes | Token password |\n| details | boolean | no | Include account details in response |"
      }
    },
    "/api.php#account/create": {
      "post": {
        "tags": ["Account"],
        "summary": "Create account",
        "operationId": "accountCreate",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/JsonRpcRequest"},
              "example": {
                "jsonrpc": "2.0",
                "method": "account/create",
                "params": {
                  "authToken": "your_token_here",
                  "tokenPass": "token_password",
                  "name": "My Server",
                  "categoryId": 1,
                  "clientId": 1,
                  "pass": "s3cret",
                  "login": "admin",
                  "url": "https://example.com",
                  "notes": "Production server",
                  "private": false,
                  "privateGroup": false,
                  "expireDate": "2025-12-31",
                  "parentId": null,
                  "tagsId": [1, 2],
                  "userGroupId": 1
                },
                "id": 1
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account created",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/JsonRpcSuccessResponse"}
              }
            }
          }
        },
        "description": "Create a new password account.\n\n**Method:** `account/create`\n\n**Params:**\n| Name | Type | Required | Description |\n|------|------|----------|-------------|\n| authToken | string | yes | API auth token |\n| tokenPass | string | yes | Token password |\n| name | string | yes | Account name |\n| categoryId | integer | yes | Category ID |\n| clientId | integer | yes | Client ID |\n| pass | string | yes | Password |\n| login | string | no | Access user |\n| url | string | no | Access URL or IP |\n| notes | string | no | Notes about the account |\n| private | boolean | no | Private account |\n| privateGroup | boolean | no | Private account for group |\n| expireDate | string | no | Password expiry date |\n| parentId | integer | no | Linked account ID |\n| tagsId | integer[] | no | Array of tag IDs |\n| userGroupId | integer | no | Group ID |"
      }
    },
    "/api.php#account/edit": {
      "post": {
        "tags": ["Account"],
        "summary": "Edit account",
        "operationId": "accountEdit",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/JsonRpcRequest"},
              "example": {
                "jsonrpc": "2.0",
                "method": "account/edit",
                "params": {
                  "authToken": "your_token_here",
                  "id": 1,
                  "name": "Updated Server Name",
                  "categoryId": 2,
                  "clientId": 1
                },
                "id": 1
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account updated",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/JsonRpcSuccessResponse"}
              }
            }
          }
        },
        "description": "Edit an existing account. Only the fields provided will be updated.\n\n**Method:** `account/edit`\n\n**Params:**\n| Name | Type | Required | Description |\n|------|------|----------|-------------|\n| authToken | string | yes | API auth token |\n| id | integer | yes | Account ID |\n| name | string | no | Account name |\n| categoryId | integer | no | Category ID |\n| clientId | integer | no | Client ID |\n| login | string | no | Access user |\n| url | string | no | Access URL or IP |\n| notes | string | no | Notes about the account |\n| private | boolean | no | Private account |\n| privateGroup | boolean | no | Private account for group |\n| expireDate | string | no | Password expiry date |\n| parentId | integer | no | Linked account ID |\n| tagsId | integer[] | no | Array of tag IDs |\n| userGroupId | integer | no | Group ID |"
      }
    },
    "/api.php#account/editPass": {
      "post": {
        "tags": ["Account"],
        "summary": "Edit account password",
        "operationId": "accountEditPass",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/JsonRpcRequest"},
              "example": {
                "jsonrpc": "2.0",
                "method": "account/editPass",
                "params": {
                  "authToken": "your_token_here",
                  "id": 1,
                  "tokenPass": "token_password",
                  "pass": "new_s3cret",
                  "expireDate": "2026-12-31"
                },
                "id": 1
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password updated",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/JsonRpcSuccessResponse"}
              }
            }
          }
        },
        "description": "Change the password of an existing account.\n\n**Method:** `account/editPass`\n\n**Params:**\n| Name | Type | Required | Description |\n|------|------|----------|-------------|\n| authToken | string | yes | API auth token |\n| id | integer | yes | Account ID |\n| tokenPass | string | yes | Token password |\n| pass | string | yes | New password |\n| expireDate | string | no | Password expiry date |"
      }
    },
    "/api.php#account/search": {
      "post": {
        "tags": ["Account"],
        "summary": "Search accounts",
        "operationId": "accountSearch",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/JsonRpcRequest"},
              "example": {
                "jsonrpc": "2.0",
                "method": "account/search",
                "params": {
                  "authToken": "your_token_here",
                  "text": "server",
                  "count": 25,
                  "categoryId": 1,
                  "clientId": null,
                  "tagsId": [1],
                  "op": "and"
                },
                "id": 1
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/JsonRpcSuccessResponse"}
              }
            }
          }
        },
        "description": "Search for accounts matching the given criteria.\n\n**Method:** `account/search`\n\n**Params:**\n| Name | Type | Required | Description |\n|------|------|----------|-------------|\n| authToken | string | yes | API auth token |\n| text | string | no | Text to search for |\n| count | integer | no | Number of results to display (default 50) |\n| categoryId | integer | no | Category ID to filter on |\n| clientId | integer | no | Client ID to filter on |\n| tagsId | integer[] | no | Array of tag IDs for filtering |\n| op | string | no | Filtering operator (`and` or `or`) |"
      }
    },
