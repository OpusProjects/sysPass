  "components": {
    "schemas": {
      "JsonRpcRequest": {
        "type": "object",
        "required": ["jsonrpc", "method", "params", "id"],
        "properties": {
          "jsonrpc": {
            "type": "string",
            "enum": ["2.0"],
            "description": "JSON-RPC version"
          },
          "method": {
            "type": "string",
            "description": "API method in the format `controller/action`",
            "example": "account/search"
          },
          "params": {
            "type": "object",
            "description": "Method parameters including authToken",
            "required": ["authToken"],
            "properties": {
              "authToken": {
                "type": "string",
                "description": "API authentication token (create in web UI under Users > Authorizations)"
              }
            },
            "additionalProperties": true
          },
          "id": {
            "type": "integer",
            "description": "Request identifier"
          }
        }
      },
      "JsonRpcSuccessResponse": {
        "type": "object",
        "properties": {
          "jsonrpc": {
            "type": "string",
            "enum": ["2.0"]
          },
          "result": {
            "type": "object",
            "properties": {
              "itemId": {
                "type": "integer",
                "nullable": true,
                "description": "ID of the created/modified item"
              },
              "result": {
                "description": "Response data (object or array depending on method)"
              },
              "resultCode": {
                "type": "integer",
                "description": "0 = success, 1 = error"
              },
              "resultMessage": {
                "type": "string",
                "nullable": true,
                "description": "Human-readable result message"
              },
              "count": {
                "type": "integer",
                "nullable": true,
                "description": "Number of items in result (for array results)"
              }
            }
          },
          "id": {
            "type": "integer",
            "description": "Echoed request identifier"
          }
        }
      },
      "JsonRpcErrorResponse": {
        "type": "object",
        "properties": {
          "jsonrpc": {
            "type": "string",
            "enum": ["2.0"]
          },
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "integer",
                "description": "JSON-RPC error code (-32700 parse, -32600 invalid request, -32601 method not found, -32602 invalid params, -32603 internal error, -32000 server error)"
              },
              "data": {
                "description": "Additional error data",
                "nullable": true
              }
            }
          },
          "id": {
            "type": "integer",
            "description": "Echoed request identifier"
          }
        }
      }
    }
  }
}
