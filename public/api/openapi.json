{
  "openapi": "3.0.3",
  "info": {
    "title": "sysPass API",
    "description": "sysPass password manager REST API.\n\n**Authentication:** Include an `Authorization: Bearer <token>` header with every request. Create tokens in the web UI under Users > Authorizations.",
    "version": "@@VERSION@@",
    "license": {
      "name": "GPL-3.0",
      "url": "https://www.gnu.org/licenses/gpl-3.0.html"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "Current server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {"name": "Account", "description": "Password account management"},
    {"name": "Category", "description": "Category management"},
    {"name": "Client", "description": "Client management"},
    {"name": "Tag", "description": "Tag management"},
    {"name": "UserGroup", "description": "User group management"},
    {"name": "EventLog", "description": "Event log search and clear"},
    {"name": "CustomField", "description": "Custom field definition management"},
    {"name": "Config", "description": "Backup and export"}
  ],
  "paths": {
    "/api/v1/accounts": {
      "get": {
        "tags": ["Account"],
        "summary": "Search accounts",
        "operationId": "searchAccounts",
        "parameters": [
          {"name": "text", "in": "query", "schema": {"type": "string"}, "description": "Text to search for"},
          {"name": "count", "in": "query", "schema": {"type": "integer", "default": 50}, "description": "Number of results"},
          {"name": "categoryId", "in": "query", "schema": {"type": "integer"}, "description": "Filter by category ID"},
          {"name": "clientId", "in": "query", "schema": {"type": "integer"}, "description": "Filter by client ID"},
          {"name": "tagsId", "in": "query", "schema": {"type": "array", "items": {"type": "integer"}}, "description": "Filter by tag IDs"},
          {"name": "op", "in": "query", "schema": {"type": "string", "enum": ["and", "or"]}, "description": "Filter operator"},
          {"name": "order", "in": "query", "schema": {"type": "integer"}, "description": "Sort order"}
        ],
        "responses": {
          "200": {"description": "Search results", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SuccessResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "500": {"description": "Server error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "post": {
        "tags": ["Account"],
        "summary": "Create account",
        "operationId": "createAccount",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "categoryId", "clientId", "pass", "tokenPass"],
                "properties": {
                  "tokenPass": {"type": "string", "description": "Token password for master key access"},
                  "name": {"type": "string"},
                  "categoryId": {"type": "integer"},
                  "clientId": {"type": "integer"},
                  "pass": {"type": "string", "description": "Account password"},
                  "login": {"type": "string"},
                  "url": {"type": "string"},
                  "notes": {"type": "string"},
                  "private": {"type": "integer"},
                  "privateGroup": {"type": "integer"},
                  "expireDate": {"type": "integer", "description": "Password expiry (unix timestamp)"},
                  "parentId": {"type": "integer"},
                  "tagsId": {"type": "array", "items": {"type": "integer"}},
                  "userGroupId": {"type": "integer"},
                  "userId": {"type": "integer"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Account created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SuccessResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/api/v1/accounts/{id}": {
      "get": {
        "tags": ["Account"],
        "summary": "View account",
        "operationId": "viewAccount",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}},
          {"name": "customFields", "in": "query", "schema": {"type": "boolean"}, "description": "Include custom fields (requires tokenPass)"},
          {"name": "tokenPass", "in": "query", "schema": {"type": "string"}, "description": "Token password (required when customFields is true)"}
        ],
        "responses": {
          "200": {"description": "Account details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SuccessResponse"}}}},
          "404": {"description": "Not found", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "put": {
        "tags": ["Account"],
        "summary": "Edit account",
        "operationId": "editAccount",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "categoryId", "clientId"],
                "properties": {
                  "name": {"type": "string"},
                  "categoryId": {"type": "integer"},
                  "clientId": {"type": "integer"},
                  "login": {"type": "string"},
                  "url": {"type": "string"},
                  "notes": {"type": "string"},
                  "private": {"type": "integer"},
                  "privateGroup": {"type": "integer"},
                  "expireDate": {"type": "integer"},
                  "parentId": {"type": "integer"},
                  "tagsId": {"type": "array", "items": {"type": "integer"}},
                  "userGroupId": {"type": "integer"},
                  "userId": {"type": "integer"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Account updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SuccessResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "delete": {
        "tags": ["Account"],
        "summary": "Delete account",
        "operationId": "deleteAccount",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Account deleted", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SuccessResponse"}}}},
          "404": {"description": "Not found", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/api/v1/accounts/{id}/password": {
      "post": {
        "tags": ["Account"],
        "summary": "View account password",
        "operationId": "viewAccountPassword",
        "description": "Decrypt and return the account password. Uses POST because tokenPass is required in the body.",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["tokenPass"],
                "properties": {
                  "tokenPass": {"type": "string", "description": "Token password for master key decryption"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Decrypted password", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SuccessResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "put": {
        "tags": ["Account"],
        "summary": "Edit account password",
        "operationId": "editAccountPassword",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["pass", "tokenPass"],
                "properties": {
                  "pass": {"type": "string", "description": "New password"},
                  "tokenPass": {"type": "string", "description": "Token password for master key access"},
                  "expireDate": {"type": "integer", "description": "Password expiry (unix timestamp)"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Password updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SuccessResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
