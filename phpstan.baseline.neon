parameters:
	ignoreErrors:
		-
			# processAccounts() is shared by both rotation paths (Account[] and AccountHistory[] callers);
			# the accurate union type surfaces that it reads AccountHistory::$mPassHash (protected) from
			# outside the class. This is a real encapsulation violation flagged independently of runtime
			# behavior: Model::__get()/__isset() proxy protected/bag property reads (see Model.php), so
			# isset($account->mPassHash) is a live check at runtime, not dead code — the arrow access here
			# just bypasses the getter. Left as-is (no runtime change).
			message: '#^Access to protected property SP\\Domain\\Account\\Models\\Account\|SP\\Domain\\Account\\Models\\AccountHistory\:\:\$mPassHash\.$#'
			identifier: property.protected
			count: 1
			path: src/Application/Account/Services/AccountMasterPassword.php

