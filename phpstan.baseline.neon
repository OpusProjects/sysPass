		-
			# Landmine (Serde templates, see PR body): deserialize()'s @return is the union
			# `T&object|array`. Tried parenthesizing to `(T&object)|array<mixed>`, which does
			# parse and does clear this entry and the phpDoc.parseError one below it — but
			# doing so makes PHPStan actually attempt template resolution at every call site
			# (previously skipped because the tag failed to parse), and none of deserialize()'s
			# current callers supply a proper class-string<T> argument (ConfigBackup::
			# configToJson() omits $class entirely; SerializedModel::deserializeWithFallback()
			# passes a plain `string $class`, not `class-string<T>`), so "fixing" this trades
			# 2 baseline entries for 7 new "Unable to resolve the template type T" ones with no
			# real type-safety gain. Reverted; left baselined.
			message: '#^Method SP\\Domain\\Common\\Adapters\\Serde\:\:deserialize\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Domain/Common/Adapters/Serde.php

