# @selectize/selectize@0.15.2 (last published 2022, no newer release) declares a
# peerDependencies range of jquery ^1.7.0 || ^2 || ^3 — stale, predates jQuery 4.0.0
# (2026). The actual dist/js/selectize.min.js calls no jQuery 4-removed API (audited
# for PR #428), so the conflict is a declaration lag, not a real incompatibility.
# legacy-peer-deps avoids npm ci/install hard-failing with ERESOLVE on this stale peer range.
legacy-peer-deps=true
